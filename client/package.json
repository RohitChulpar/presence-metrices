{
  "name": "presence-metrics",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Presence and Focus Analytics System",
  "author": "Your Name",
  "type": "module",
  "main": "public/electron.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron public/electron.cjs\"",
    "build-windows": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "electron-is-dev": "^3.0.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.presencemetrics.app",
    "productName": "PresenceMetrics",
    "files": [
      "dist/**/*",
      "public/electron.cjs",
      "public/logo.png"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "backend"
      },
      {
        "from": "../ai-engine",
        "to": "ai-engine"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    }
  }
}